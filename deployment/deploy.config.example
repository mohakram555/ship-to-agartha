# Deployment Configuration
# ------------------------
# INSTRUCTIONS:
# 1. Copy this file to 'deploy.config': cp deploy.config.example deploy.config
# 2. Replace every placeholder value below with your own server details.
# 3. Never commit deployment/deploy.config. It is ignored by .gitignore.

# Public server IP address or hostname.
VPS_HOST="<YOUR_SERVER_IP_OR_HOSTNAME>"

# SSH user for the server. Common values: ubuntu, debian, root.
VPS_USER="<YOUR_SSH_USER>"

# Path to your SSH private key. Use $HOME instead of ~ for portability.
SSH_KEY_PATH="$HOME/.ssh/<YOUR_PRIVATE_KEY>"

# Directory on the server that Nginx will serve.
REMOTE_DIR="/var/www/agartha-false-guide"

# Used for the Nginx site filename.
PROJECT_NAME="agartha-false-guide"

# Public domain configured in DNS for this site.
DOMAIN="<YOUR_DOMAIN>"
